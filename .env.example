# Copy this file to `.env` and fill the values before running `docker-compose up`

# n8n
N8N_PORT=5678
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=changeme
WEBHOOK_URL=http://localhost:5678
GENERIC_TIMEZONE=America/Bogota

# Evolution API
EVOLUTION_PORT=8080
EVOLUTION_API_KEY=your_evolution_api_key_here
EVO_QRCODE_LIMIT=30

# Claude / Anthropic
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google Sheets
GOOGLE_SHEETS_CREDENTIALS_JSON_PATH=./credentials/google-sheets-credentials.json
GOOGLE_SHEETS_SHEET_ID=your_google_sheet_id_here
MY_PERSONAL_PHONE=+57XXXXXXXXXXX
