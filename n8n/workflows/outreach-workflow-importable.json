      "name": "Schedule Trigger",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1,
      "position": [250, 200]
    },
    {
      "parameters": {
        "sheetId": "={{$env.GOOGLE_SHEETS_SHEET_ID}}",
