      "parameters": {
        "url": "https://api.anthropic.com/v1/complete",
        "method": "POST",
        "jsonParameters": true,
        "options": {},
        "bodyParametersJson": "={\"model\":\"claude\",\"prompt\":\"{{$json.prompt}}\",\"max_tokens\":300}"
      },
